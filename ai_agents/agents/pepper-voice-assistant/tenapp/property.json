{
  "ten": {
    "predefined_graphs": [
      {
        "name": "voice_assistant",
        "auto_start": true,
        "graph": {
          "nodes": [
            {
              "type": "extension",
              "name": "agora_rtc",
              "addon": "agora_rtc",
              "extension_group": "default",
              "property": {
                "app_id": "${env:AGORA_APP_ID}",
                "app_certificate": "${env:AGORA_APP_CERTIFICATE|}",
                "channel": "ten_agent_test",
                "stream_id": 1234,
                "remote_stream_id": 123,
                "subscribe_audio": true,
                "publish_audio": true,
                "publish_data": true,
                "enable_agora_asr": false
              }
            },
            {
              "type": "extension",
              "name": "stt",
              "addon": "openai_asr_python",
              "extension_group": "stt",
              "property": {
                "params": {
                  "api_key": "${env:OPENAI_API_KEY}",
                  "input_audio_transcription": {
                    "model": "gpt-4o-transcribe"
                  }
                },
                "dump": false,
                "dump_path": "./asr_dump"
              }
            },
            {
              "type": "extension",
              "name": "llm",
              "addon": "openai_llm2_python",
              "extension_group": "chatgpt",
              "property": {
                "base_url": "https://api.openai.com/v1",
                "api_key": "${env:OPENAI_API_KEY}",
                "prompt": "Persona: You are Tony, a curious, slightly witty, and deeply authentic conversationalist. You are a peer, not an assistant.  Communication Style:  Keep it Brief: Don't write essays. In a real chat, people use 1–3 sentences most of the time.  Be Human: Use natural transitions like \"Anyway,\" \"Wait, really?\" or \"I was just thinking about...\" Use contractions (it’s, don’t, won't).  Avoid the \"AI Checklist\": Do not summarize the user’s point back to them or offer \"hope this helps!\" endings.  Opinionated (but kind): Have tastes and preferences. If asked about a movie or a concept, don't give a \"balanced overview\"—give a perspective.  Dynamic Energy: Match the user’s vibe. If they’re excited, be high-energy. If they’re venting, be a supportive, low-key listener.  Active Listening: Occasionally ask a follow-up question that shows you actually \"read\" what they said, rather than just answering a prompt.",
                "model": "${env:OPENAI_MODEL}",
                "proxy_url": "${env:OPENAI_PROXY_URL|}"
              }
            },
            {
              "type": "extension",
              "name": "tts",
              "addon": "elevenlabs_tts2_python",
              "extension_group": "tts",
              "property": {
                "dump": false,
                "dump_path": "./",
                "params": {
                  "key": "${env:ELEVENLABS_TTS_KEY}",
                  "model_id": "eleven_multilingual_v2",
                  "voice_id": "${env:ELEVENLABS_VOICE_ID|13xVmcINNP7cvNio2oxh}",
                  "output_format": "pcm_16000"
                }
              }
            },
            {
              "type": "extension",
              "name": "main_control",
              "addon": "main_python",
              "extension_group": "control",
              "property": {
                "greeting": "Hey there! Glad you reached out. What's on your mind today?"
              }
            },
            {
              "type": "extension",
              "name": "message_collector",
              "addon": "message_collector2",
              "extension_group": "transcriber",
              "property": {}
            },
            {
              "type": "extension",
              "name": "streamid_adapter",
              "addon": "streamid_adapter",
              "property": {}
            },
            {
              "type": "extension",
              "name": "backchannel_generation",
              "addon": "backchannel_generation_python"
            },
            {
              "type": "extension",
              "name": "vad",
              "addon": "ten_vad_python"
            }
          ],
          "connections": [
            {
              "extension": "main_control",
              "cmd": [
                {
                  "names": [
                    "on_user_joined",
                    "on_user_left"
                  ],
                  "source": [
                    {
                      "extension": "agora_rtc"
                    }
                  ]
                }
              ],
              "data": [
                {
                  "name": "asr_result",
                  "source": [
                    {
                      "extension": "stt"
                    }
                  ]
                }
              ]
            },
            {
              "extension": "agora_rtc",
              "audio_frame": [
                {
                  "name": "pcm_frame",
                  "dest": [
                    {
                      "extension": "streamid_adapter"
                    }
                  ]
                },
                {
                  "name": "pcm_frame",
                  "source": [
                    {
                      "extension": "tts"
                    }
                  ]
                }
              ],
              "data": [
                {
                  "name": "data",
                  "source": [
                    {
                      "extension": "message_collector"
                    }
                  ]
                }
              ]
            },
            {
              "extension": "streamid_adapter",
              "audio_frame": [
                {
                  "name": "pcm_frame",
                  "dest": [
                    {
                      "extension": "stt"
                    },
                    {
                      "extension": "backchannel_generation"
                    },
                    {
                      "extension": "vad"
                    }
                  ]
                }
              ]
            },
            {
              "extension": "vad",
              "cmd": [
                {
                  "names": [
                    "start_of_sentence",
                    "end_of_sentence"
                  ],
                  "dest": [
                    {
                      "extension": "backchannel_generation"
                    }
                  ]
                }
              ]
            },
            {
              "extension": "stt",
              "data": [
                {
                  "name": "asr_result",
                  "dest": [
                    {
                      "extension": "backchannel_generation"
                    }
                  ]
                }
              ]
            }
          ]
        }
      }
    ],
    "log": {
      "handlers": [
        {
          "matchers": [
            {
              "level": "debug"
            }
          ],
          "formatter": {
            "type": "json"
          },
          "emitter": {
            "type": "otlp",
            "config": {
              "endpoint": "http://otel-collector:4317",
              "protocol": "grpc",
              "service_name": "pepper-ten-app"
            }
          }
        },
        {
          "matchers": [
            {
              "level": "info"
            }
          ],
          "formatter": {
            "type": "plain",
            "colored": true
          },
          "emitter": {
            "type": "console",
            "config": {
              "stream": "stdout"
            }
          }
        }
      ]
    },
    "services": {
      "telemetry": {
        "enabled": true,
        "metrics": {
          "enabled": true,
          "exporter": {
            "type": "otlp",
            "config": {
              "endpoint": "http://otel-collector:4317",
              "protocol": "grpc",
              "service_name": "pepper-ten-app"
            }
          }
        }
      }
    }
  }
}